# ================================================================
# CodeRoute Guinée — Variables d'environnement PRODUCTION
# Copiez ce fichier en .env sur le serveur de production
# NE JAMAIS commiter .env avec les vraies valeurs
# ================================================================

PROJECT_NAME="CodeRoute Guinée API"
ENVIRONMENT="production"
API_V1_PREFIX="/api/v1"

# ── Sécurité ────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
SECRET_KEY=REMPLACER_PAR_UNE_CLE_ALEATOIRE_64_CHARS

# Token pour créer les premiers comptes admin (désactiver après bootstrap)
ADMIN_REGISTRATION_TOKEN=REMPLACER_PAR_TOKEN_BOOTSTRAP

ACCESS_TOKEN_EXPIRE_MINUTES=120
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# ── Base de données ──────────────────────────────────────────────
# PostgreSQL sur le réseau Docker interne
DATABASE_URL=postgresql+psycopg://coderoute:MOT_DE_PASSE_FORT@postgres:5432/coderoute
AUTO_CREATE_TABLES=false

POSTGRES_DB=coderoute
POSTGRES_USER=coderoute
POSTGRES_PASSWORD=MOT_DE_PASSE_FORT_POSTGRESQL

# ── CORS ────────────────────────────────────────────────────────
CORS_ORIGINS=https://coderoute.gov.gn,https://admin.coderoute.gov.gn
ALLOWED_HOSTS=api.coderoute.gov.gn

# ── Documentation API ────────────────────────────────────────────
# Désactiver en production (false)
ENABLE_API_DOCS=false

# ── Ports (réseau interne Docker) ───────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=4173

# ── Compte bootstrap super_admin ────────────────────────────────
# Créé au premier démarrage si absent — CHANGER IMMÉDIATEMENT après
BOOTSTRAP_ADMIN_EMAIL=super_admin@coderoute.gov.gn
BOOTSTRAP_ADMIN_PASSWORD=REMPLACER_IMMEDIATEMENT
BOOTSTRAP_ADMIN_FULL_NAME=Directeur National CodeRoute

# ── URLs publiques ───────────────────────────────────────────────
VITE_API_BASE_URL=https://api.coderoute.gov.gn
VITE_API_URL=https://api.coderoute.gov.gn/api/v1

# ── Mobile Money Guinée ─────────────────────────────────────────
MOBILE_MONEY_MODE=production

# Orange Money Guinée — https://developer.orange.com
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_MERCHANT_CODE=
ORANGE_MONEY_BASE_URL=https://api.orange.com

# MTN Mobile Money — https://momodeveloper.mtn.com
MTN_MONEY_SUBSCRIPTION_KEY=
MTN_MONEY_API_USER_ID=
MTN_MONEY_API_KEY=
MTN_MONEY_ENVIRONMENT=mtnguinee
MTN_MONEY_BASE_URL=https://api.mtn.com

# ── Monitoring Sentry ────────────────────────────────────────────
# Créer un projet sur https://sentry.io → FastAPI → copier le DSN
SENTRY_DSN=https://xxxx@oyyy.ingest.sentry.io/zzzz
SENTRY_ENVIRONMENT=production
SENTRY_SAMPLE_RATE=0.2

# ── Backup ──────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=30
