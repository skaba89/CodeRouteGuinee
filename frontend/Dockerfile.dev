FROM node:22-alpine

WORKDIR /app

# Installer seulement les dépendances (le code est monté via volume)
COPY package.json package-lock.json ./
RUN npm ci

# Le code source est monté via le volume ./frontend:/app dans docker-compose.yml
# node_modules est préservé par le volume anonyme /app/node_modules

CMD ["npm", "run", "dev"]
