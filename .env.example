PROJECT_NAME="CodeRoute Guinee API"
ENVIRONMENT="production"
API_V1_PREFIX="/api/v1"
SECRET_KEY="replace-with-a-long-random-production-secret"
ADMIN_REGISTRATION_TOKEN="replace-with-a-private-bootstrap-token"
ACCESS_TOKEN_EXPIRE_MINUTES=120
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

DATABASE_URL="postgresql+psycopg://coderoute:coderoute@postgres:5432/coderoute"
AUTO_CREATE_TABLES=false
CORS_ORIGINS="https://coderoute.gov.gn,https://admin.coderoute.gov.gn"
ALLOWED_HOSTS="api.coderoute.gov.gn"
ENABLE_API_DOCS=false

POSTGRES_DB=coderoute
POSTGRES_USER=coderoute
POSTGRES_PASSWORD="replace-with-a-strong-postgres-password"
BACKEND_PORT=8000
FRONTEND_PORT=5173
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION_REQUIRED=true

BOOTSTRAP_ADMIN_EMAIL="admin@coderoute.gov.gn"
BOOTSTRAP_ADMIN_PASSWORD="replace-with-a-strong-temporary-password"
BOOTSTRAP_ADMIN_FULL_NAME="Administrateur National CodeRoute"

VITE_API_BASE_URL="https://api.coderoute.gov.gn"
VITE_API_URL="https://api.coderoute.gov.gn/api/v1"

# Mobile Money — mode sandbox par défaut, passer à 'production' pour les vrais paiements
MOBILE_MONEY_MODE=sandbox

# Orange Money Guinée (Orange Developer Africa)
# Obtenir sur https://developer.orange.com après inscription Marchand GN
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_MERCHANT_CODE=
ORANGE_MONEY_BASE_URL=https://api.orange.com

# MTN Mobile Money Guinée (MoMo API)
# Obtenir sur https://momodeveloper.mtn.com après onboarding Guinée
MTN_MONEY_SUBSCRIPTION_KEY=
MTN_MONEY_API_USER_ID=
MTN_MONEY_API_KEY=
MTN_MONEY_ENVIRONMENT=sandbox
MTN_MONEY_BASE_URL=https://sandbox.momodeveloper.mtn.com

# Monitoring Sentry (optionnel — désactivé si absent)
# Créer un projet sur https://sentry.io → FastAPI → copier le DSN
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_SAMPLE_RATE=0.2

# ── Email — Brevo (anciennement Sendinblue) ────────────────────────
# Créer un compte sur https://brevo.com (plan gratuit = 300 emails/jour)
# Aller dans SMTP & API > Clés API > Générer une clé API
BREVO_API_KEY=xkeysib-votre-cle-api-brevo
EMAIL_FROM=noreply@coderoute.gov.gn
EMAIL_FROM_NAME=CodeRoute Guinée

# ── Mobile Money — Orange Money Guinée ────────────────────────────
# Obtenir via https://developer.orange.com/apis/orange-money-webpay-gn
# Sandbox disponible pour les tests sans transaction réelle
ORANGE_MONEY_CLIENT_ID=votre-client-id-orange
ORANGE_MONEY_CLIENT_SECRET=votre-client-secret-orange
ORANGE_MONEY_MERCHANT_CODE=votre-code-marchand
ORANGE_MONEY_BASE_URL=https://api.orange.com
# En production :
# ORANGE_MONEY_BASE_URL=https://api.orange.com

# ── Mobile Money — MTN MoMo Guinée ────────────────────────────────
# Obtenir via https://momodeveloper.mtn.com (sandbox gratuit)
MTN_MONEY_SUBSCRIPTION_KEY=votre-subscription-key-mtn
MTN_MONEY_API_USER_ID=votre-api-user-id-uuid
MTN_MONEY_API_KEY=votre-api-key-mtn
MTN_MONEY_ENVIRONMENT=sandbox
# En production : MTN_MONEY_ENVIRONMENT=mtnguinee

# ── Mobile Money — Wave ────────────────────────────────────────────
# Obtenir via https://wave.com/en/business/api (contacter Wave Business)
WAVE_API_KEY=votre-api-key-wave
WAVE_WEBHOOK_SECRET=votre-secret-hmac-pour-webhooks

# ── Scalabilité DB pool ────────────────────────────────────────────
# Adapter selon : workers × (pool_size + max_overflow) ≤ PG max_connections - 10
# Exemple serveur 4 CPU (workers = 9) : 9 × 50 = 450 → PG max_connections >= 460
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ── Gunicorn workers ───────────────────────────────────────────────
# Par défaut : 2×CPU+1 (auto-détecté)
# Surcharger ici pour fixer un nombre précis :
# WEB_CONCURRENCY=9

# ── Bootstrap admin initial ────────────────────────────────────────
# Pour créer le premier super admin via : python -m app.bootstrap_admin
BOOTSTRAP_ADMIN_EMAIL=admin@coderoute.gov.gn
BOOTSTRAP_ADMIN_PASSWORD=VotreMotDePasse12Caracteres!
BOOTSTRAP_ADMIN_FULL_NAME=Administrateur National DNTT
