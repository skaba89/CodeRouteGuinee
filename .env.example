PROJECT_NAME="CodeRoute Guinee API"
API_V1_PREFIX="/api/v1"
SECRET_KEY="replace-with-a-long-random-production-secret"
ADMIN_REGISTRATION_TOKEN="replace-with-a-private-bootstrap-token"
ACCESS_TOKEN_EXPIRE_MINUTES=120
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

DATABASE_URL="postgresql+psycopg://coderoute:coderoute@postgres:5432/coderoute"
AUTO_CREATE_TABLES=false
CORS_ORIGINS="https://coderoute.gov.gn,https://admin.coderoute.gov.gn"

POSTGRES_DB=coderoute
POSTGRES_USER=coderoute
POSTGRES_PASSWORD="replace-with-a-strong-postgres-password"

BOOTSTRAP_ADMIN_EMAIL="admin@coderoute.gov.gn"
BOOTSTRAP_ADMIN_PASSWORD="replace-with-a-strong-temporary-password"
BOOTSTRAP_ADMIN_FULL_NAME="Administrateur National CodeRoute"

VITE_API_BASE_URL="http://localhost:8000"
VITE_API_URL="http://localhost:8000/api/v1"
