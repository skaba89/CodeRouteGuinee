PROJECT_NAME="CodeRoute Guinee API"
ENVIRONMENT="production"
API_V1_PREFIX="/api/v1"
SECRET_KEY="replace-with-a-long-random-production-secret"
ADMIN_REGISTRATION_TOKEN="replace-with-a-private-bootstrap-token"
ACCESS_TOKEN_EXPIRE_MINUTES=120
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

DATABASE_URL="postgresql+psycopg://coderoute:coderoute@postgres:5432/coderoute"
AUTO_CREATE_TABLES=false
CORS_ORIGINS="https://coderoute.gov.gn,https://admin.coderoute.gov.gn"
ALLOWED_HOSTS="api.coderoute.gov.gn"
ENABLE_API_DOCS=false

POSTGRES_DB=coderoute
POSTGRES_USER=coderoute
POSTGRES_PASSWORD="replace-with-a-strong-postgres-password"
BACKEND_PORT=8000
FRONTEND_PORT=5173
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION_REQUIRED=true

BOOTSTRAP_ADMIN_EMAIL="admin@coderoute.gov.gn"
BOOTSTRAP_ADMIN_PASSWORD="replace-with-a-strong-temporary-password"
BOOTSTRAP_ADMIN_FULL_NAME="Administrateur National CodeRoute"

VITE_API_BASE_URL="https://api.coderoute.gov.gn"
VITE_API_URL="https://api.coderoute.gov.gn/api/v1"

# Mobile Money — mode sandbox par défaut, passer à 'production' pour les vrais paiements
MOBILE_MONEY_MODE=sandbox

# Orange Money Guinée (Orange Developer Africa)
# Obtenir sur https://developer.orange.com après inscription Marchand GN
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_MERCHANT_CODE=
ORANGE_MONEY_BASE_URL=https://api.orange.com

# MTN Mobile Money Guinée (MoMo API)
# Obtenir sur https://momodeveloper.mtn.com après onboarding Guinée
MTN_MONEY_SUBSCRIPTION_KEY=
MTN_MONEY_API_USER_ID=
MTN_MONEY_API_KEY=
MTN_MONEY_ENVIRONMENT=sandbox
MTN_MONEY_BASE_URL=https://sandbox.momodeveloper.mtn.com
