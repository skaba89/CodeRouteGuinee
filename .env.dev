# ════════════════════════════════════════════════════════════════
# .env.dev — Configuration DÉVELOPPEMENT LOCAL (Docker Compose)
# Commande : docker compose up --build
# ════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────
PROJECT_NAME="CodeRoute Guinée API"
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# ── Sécurité (valeurs de dev — NE PAS utiliser en production) ─
SECRET_KEY=dev-secret-key-coderoute-guinee-2026-not-for-production
ADMIN_REGISTRATION_TOKEN=dev-admin-token-2026
ACCESS_TOKEN_EXPIRE_MINUTES=120
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# ── Base de données ────────────────────────────────────────────
# Attention : DATABASE_URL est forcé dans docker-compose.yml
# (hostname = nom du service Docker "postgres", pas localhost)
DATABASE_URL=postgresql+psycopg://coderoute:coderoute@postgres:5432/coderoute
AUTO_CREATE_TABLES=false

POSTGRES_DB=coderoute
POSTGRES_USER=coderoute
POSTGRES_PASSWORD=coderoute

# ── Ports ──────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ── CORS (dev : autoriser localhost) ───────────────────────────
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# ── Docs API (activé en dev) ───────────────────────────────────
ENABLE_API_DOCS=true

# ── Email (dev : désactivé — log uniquement) ───────────────────
# Laisser vide = emails loggués en console, aucun envoi réel
BREVO_API_KEY=
EMAIL_FROM=noreply@coderoute.local
EMAIL_FROM_NAME=CodeRoute Dev

# ── Mobile Money (dev : sandbox automatique) ──────────────────
# Laisser vide = paiements simulés (sandbox)
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
WAVE_API_KEY=
WAVE_WEBHOOK_SECRET=

# ── Vite frontend ──────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000/api/v1
