# ================================================================
# CodeRoute Guinée — Configuration développement local
# Copiez ce fichier en .env : cp .env.dev .env
# ================================================================

PROJECT_NAME="CodeRoute Guinée API"
ENVIRONMENT="development"
API_V1_PREFIX="/api/v1"

# Clé secrète dev (CHANGER en production)
SECRET_KEY="coderoute-dev-secret-2026-change-in-prod-min-32chars"
ADMIN_REGISTRATION_TOKEN="dev-bootstrap-token-2026"
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Rate limiting
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# Base de données (Docker Compose)
DATABASE_URL="postgresql+psycopg://coderoute:coderoute@postgres:5432/coderoute"
AUTO_CREATE_TABLES=false

# PostgreSQL
POSTGRES_DB=coderoute
POSTGRES_USER=coderoute
POSTGRES_PASSWORD=coderoute

# CORS — autoriser le frontend dev
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173"
ALLOWED_HOSTS="localhost,127.0.0.1"

# Swagger UI activé en développement
ENABLE_API_DOCS=true

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Compte bootstrap super_admin (créé au premier démarrage si absent)
BOOTSTRAP_ADMIN_EMAIL="super_admin@coderoute.gov.gn"
BOOTSTRAP_ADMIN_PASSWORD="CodeRoute2026!"
BOOTSTRAP_ADMIN_FULL_NAME="Directeur National CodeRoute"

# Frontend — URL de l'API
VITE_API_BASE_URL="http://localhost:8000"
VITE_API_URL="http://localhost:8000/api/v1"

# Mobile Money (sandbox par défaut)
MOBILE_MONEY_MODE=sandbox

# Monitoring (désactivé en dev)
SENTRY_DSN=

# Rétention backup
BACKUP_RETENTION_DAYS=30
