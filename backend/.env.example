# .env.example — CodeRoute Guinée
# Copier en .env et remplir les valeurs réelles (ne jamais commiter .env)

# ── Sécurité ─────────────────────────────────────────────────────
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_with_python_secrets_token_hex_32
CSRF_SECRET=CHANGE_ME_generate_with_python_secrets_token_hex_32
ADMIN_REGISTRATION_TOKEN=CHANGE_ME_generate_with_python_secrets_token_urlsafe_24

# ── Base de données ───────────────────────────────────────────────
# Format Neon PostgreSQL : postgresql+psycopg://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=CHANGE_ME_neon_pooler_url
ALEMBIC_DATABASE_URL=CHANGE_ME_neon_direct_url

# ── Bootstrap admin ───────────────────────────────────────────────
BOOTSTRAP_ADMIN_EMAIL=super_admin@coderoute.gov.gn
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_strong_password_min_16_chars
BOOTSTRAP_ADMIN_NAME=Directeur National CodeRoute

# ── Application ───────────────────────────────────────────────────
ENVIRONMENT=development
ENABLE_API_DOCS=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# ── Email Brevo (optionnel) ───────────────────────────────────────
BREVO_API_KEY=CHANGE_ME_brevo_api_key
EMAIL_FROM=noreply@coderoute.gov.gn
EMAIL_FROM_NAME=CodeRoute Guinée — DNTT

# ── Mobile Money (sandbox par défaut) ────────────────────────────
MOBILE_MONEY_MODE=sandbox

# ── Tokens ───────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Performance DB ────────────────────────────────────────────────
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=3
DB_POOL_RECYCLE=60

# ── Hébergement média (Cloudinary) — optionnel ──────────────────────────────
# Permet de téléverser photos/vidéos directement depuis l'admin.
# Créez un compte gratuit sur cloudinary.com → Dashboard → Product Environment.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=coderoute/questions
